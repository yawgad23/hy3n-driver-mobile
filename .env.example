# ─── HY3N Driver App — Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in your values before running the app.

# ── Server / Auth ─────────────────────────────────────────────────────────────
JWT_SECRET=change_me_in_production
NODE_ENV=development
PORT=3000

# ── Database (MySQL / TiDB) ───────────────────────────────────────────────────
DATABASE_URL=mysql://user:password@host:3306/hy3n_driver

# ── Manus Platform (leave blank if self-hosting) ─────────────────────────────
VITE_APP_ID=
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# ── Firebase Admin SDK ────────────────────────────────────────────────────────
# Paste the full JSON string from your Firebase service account key file
FIREBASE_SERVICE_ACCOUNT=

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=hy3ntransportservices@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=HY3N Driver <hy3ntransportservices@gmail.com>

# ── Hubtel Mobile Money ───────────────────────────────────────────────────────
HUBTEL_API_ID=your_hubtel_api_id
HUBTEL_API_KEY=your_hubtel_api_key
HUBTEL_POS_NUMBER=your_hubtel_pos_number

# ── Admin Dashboard ───────────────────────────────────────────────────────────
ADMIN_DASHBOARD_PIN=5809

# ── Google Maps (for navigation deep links) ───────────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
