# ─── HY3N Driver App — Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in your values before running the app.
#
# Everything the backend used to need (Firebase, Hubtel, email, admin PIN,
# etc.) now lives in the hy3n-backend repo's own .env — this app only needs
# to know where that backend is running.

NODE_ENV=development

# ── Mobile app -> hy3n-backend API ────────────────────────────────────────────
# Point this at the deployed Cloud Run URL, or at a locally running
# hy3n-backend instance (iOS Simulator can use localhost; a physical device
# needs your machine's LAN IP, e.g. http://192.168.1.50:3000).
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# ── Google Maps (Places autocomplete, used client-side for map rendering) ────
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
